<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
   version="4.0">
    <servlet>
        <servlet-name>ModelViewController</servlet-name>
        <servlet-class>com.atcloud.servlets.ModelViewController</servlet-class>
        <init-param>
            <param-name>mvcConfigFile</param-name>
            <param-value>/WEB-INF/mvc-controler.xml</param-value>
        </init-param>
        <init-param>
            <param-name>dataSourceName</param-name>
            <param-value>jdbc/intran</param-value>
        </init-param>
        <init-param>
            <param-name>sessionFailPage</param-name>
            <param-value>/ecommerce/index.jsp</param-value>
        </init-param>
    </servlet>
    <servlet>
        <servlet-name>Log4JInitServlet</servlet-name>
        <servlet-class>com.atcloud.servlets.Log4JInitServlet</servlet-class>
        <init-param>
            <param-name>log4j-properties-location</param-name>
            <param-value>/WEB-INF/log4j.properties</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet>
        <servlet-name>CargaInformacion</servlet-name>
        <servlet-class>mx.intran.ecommerce.servlet.CargaInformacion</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ModelViewController</servlet-name>
        <url-pattern>/MVC</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CargaInformacion</servlet-name>
        <url-pattern>/CargaInformacion</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <resource-ref>
        <res-ref-name>jdbc/intran</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
        <res-sharing-scope>Shareable</res-sharing-scope>
    </resource-ref>
</web-app>
